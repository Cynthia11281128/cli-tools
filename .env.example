# Copy this file to .env and edit the values for your machine.
# .env is ignored by Git and should contain private local configuration.

# SSH target used by `cli-tools port-list --remote` and `cli-tools ssh-tunnel`.
CLI_TOOLS_SSH_REMOTE=user@example.com

# Optional: set this when cli-tools is not on PATH on the remote machine.
# CLI_TOOLS_REMOTE_CLI=/home/user/cli-tools/bin/cli-tools

# Initial directory for `cli-tools codex-add` interactive path completion.
CODEX_ADD_ROOT=/path/to/root

# Password used by `cli-tools codex-web`.
CODEX_WEB_PASSWORD=change-me
