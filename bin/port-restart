#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'USAGE'
Usage:
  cli-tools port-restart
  cli-tools port-restart <name-or-port> [...]
  port-restart
  port-restart <name-or-port> [...]

Restart one or more named port services managed by cli-tools.

Run without arguments to choose one or more services interactively.

Targets may be service names or managed port numbers. Numeric targets are
resolved as ports first, then service names. Interactive numeric selections are
resolved as list indexes first.

Only currently running services can be restarted. Restart replays the command
recorded by port-start from the service process' current working directory.
USAGE
}

resolve_self() {
  local source="$1"
  local dir link

  while [[ -L "$source" ]]; do
    dir="$(CDPATH= cd -- "$(dirname -- "$source")" && pwd)" || return 1
    link="$(readlink -- "$source")" || return 1

    if [[ "$link" == /* ]]; then
      source="$link"
    else
      source="$dir/$link"
    fi
  done

  dir="$(CDPATH= cd -- "$(dirname -- "$source")" && pwd)" || return 1
  printf '%s/%s\n' "$dir" "$(basename -- "$source")"
}

script_path="$(resolve_self "${BASH_SOURCE[0]}")" || {
  printf 'error: failed to resolve script path\n' >&2
  exit 1
}
bin_dir="$(dirname -- "$script_path")"
repo_dir="$(CDPATH= cd -- "$bin_dir/.." && pwd)" || {
  printf 'error: failed to resolve cli-tools root\n' >&2
  exit 1
}

# shellcheck source=../lib/port-registry.bash
source "$repo_dir/lib/port-registry.bash"

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

port_number_for_target() {
  local target="$1"
  local port_number

  [[ "$target" =~ ^[0-9]+$ ]] || return 1
  port_number=$((10#$target))
  (( port_number >= 1 && port_number <= 65535 )) || return 1
  printf '%s\n' "$port_number"
}

registry_line_for_target() {
  local target="$1"
  local target_port=""
  local line=""

  if target_port="$(port_number_for_target "$target")"; then
    line="$(port_registry_line_by_port "$target_port" || true)"
    if [[ -n "$line" ]]; then
      printf '%s\n' "$line"
      return 0
    fi
  fi

  port_validate_name "$target"

  line="$(port_registry_line_by_name "$target" || true)"
  if [[ -n "$line" ]]; then
    printf '%s\n' "$line"
    return 0
  fi

  if [[ "$target" =~ ^[0-9]+$ ]]; then
    if [[ -n "$target_port" ]]; then
      port_die "unknown named port service or managed port: $target"
    fi
    port_die "unknown named port service, and not a valid port: $target"
  fi

  port_die "unknown named port service: $target"
}

read_interactive_targets() {
  local -a lines=()
  local -a tokens=()
  local line name port pid start_time log_path command_text
  local index selection selected_index token
  local name_width=4 port_width=4

  if [[ ! -t 0 || ! -t 1 ]]; then
    usage >&2
    port_die "interactive mode requires a terminal; pass <name-or-port> for non-interactive use"
  fi

  port_registry_lock
  port_registry_cleanup_stale

  if [[ "$(port_registry_count_entries)" -eq 0 ]]; then
    port_registry_unlock
    printf 'No named port services.\n'
    exit 0
  fi

  mapfile -t lines < <(sort -f -t $'\t' -k1,1 -k2,2n -- "$PORT_REGISTRY")
  port_registry_unlock

  for line in "${lines[@]}"; do
    [[ -n "$line" ]] || continue
    IFS=$'\t' read -r name port pid start_time log_path command_text <<<"$line"
    if (( ${#name} > name_width )); then
      name_width="${#name}"
    fi
    if (( ${#port} > port_width )); then
      port_width="${#port}"
    fi
  done

  printf 'Available named port services:\n'
  printf '  %-4s %-*s %-*s %s\n' "#" "$name_width" "NAME" "$port_width" "PORT" "PID"

  index=1
  for line in "${lines[@]}"; do
    [[ -n "$line" ]] || continue
    IFS=$'\t' read -r name port pid start_time log_path command_text <<<"$line"
    printf '  %-4s %-*s %-*s %s\n' "$index" "$name_width" "$name" "$port_width" "$port" "$pid"
    index=$((index + 1))
  done

  printf 'Select service(s) to restart (numbers, names, or ports; separate with spaces or commas): '
  IFS= read -r selection || port_die "selection is required"
  [[ -n "$selection" ]] || port_die "selection is required"

  selection="${selection//,/ }"
  read -r -a tokens <<<"$selection"
  [[ "${#tokens[@]}" -gt 0 ]] || port_die "selection is required"

  PORT_RESTART_INTERACTIVE_TARGETS=()
  for token in "${tokens[@]}"; do
    if [[ "$token" =~ ^[0-9]+$ ]]; then
      selected_index=$((10#$token))
      if (( selected_index >= 1 && selected_index <= ${#lines[@]} )); then
        line="${lines[$((selected_index - 1))]}"
        IFS=$'\t' read -r name port pid start_time log_path command_text <<<"$line"
        token="$name"
      fi
    fi

    PORT_RESTART_INTERACTIVE_TARGETS+=("$token")
  done
}

parse_command_text() {
  local command_text="$1"

  PORT_RESTART_COMMAND_ARGS=()
  if ! eval "PORT_RESTART_COMMAND_ARGS=($command_text)"; then
    port_die "failed to parse recorded command: $command_text"
  fi
  [[ "${#PORT_RESTART_COMMAND_ARGS[@]}" -gt 0 ]] ||
    port_die "recorded command is empty"
}

stop_process_group() {
  local name="$1"
  local pid="$2"

  if ! port_service_alive "$pid"; then
    port_die "named port service is no longer running: $name"
  fi

  kill -TERM -- "-$pid" 2>/dev/null || true

  for ((attempt = 1; attempt <= 50; attempt++)); do
    if ! port_service_alive "$pid"; then
      return 0
    fi
    sleep 0.1
  done

  port_warn "service did not stop after TERM; sending KILL"
  kill -KILL -- "-$pid" 2>/dev/null || true
  sleep 0.2

  if port_service_alive "$pid"; then
    port_die "service still appears to be running: $name"
  fi
}

start_restarted_service() {
  local name="$1"
  local port="$2"
  local cwd="$3"
  local command_text="$4"
  local timestamp start_time log_path pid status

  parse_command_text "$command_text"

  timestamp="$(date -u '+%Y%m%dT%H%M%SZ')"
  start_time="$(date -u '+%Y-%m-%dT%H:%M:%SZ')"
  log_path="$PORT_LOG_DIR/${name}-${port}-${timestamp}.log"

  : >"$log_path"
  bash -c 'cd "$1" || exit 127; shift; exec setsid "$@"' \
    bash "$cwd" "${PORT_RESTART_COMMAND_ARGS[@]}" >>"$log_path" 2>&1 </dev/null &
  pid="$!"

  status="starting"
  for ((attempt = 1; attempt <= 50; attempt++)); do
    if ! port_service_alive "$pid" && ! port_pid_alive "$pid"; then
      port_die "command exited before port $port restarted; log: $log_path"
    fi
    if port_is_listening "$port"; then
      status="listening"
      break
    fi
    sleep 0.1
  done

  port_registry_append "$name" "$port" "$pid" "$start_time" "$log_path" "$command_text"

  printf 'Restarted named port service: %s\n' "$name"
  printf '  port: %s\n' "$port"
  printf '  pid: %s\n' "$pid"
  printf '  log: %s\n' "$log_path"

  if [[ "$status" == "listening" ]]; then
    printf '  status: listening\n'
  else
    printf '  status: running, but port is not listening yet\n'
  fi
}

restart_registry_line() {
  local line="$1"
  local cwd="$2"
  local name port pid command_text

  port_parse_registry_line "$line"
  name="$PORT_ENTRY_NAME"
  port="$PORT_ENTRY_PORT"
  pid="$PORT_ENTRY_PID"
  command_text="$PORT_ENTRY_COMMAND"

  printf 'Restarting named port service: %s\n' "$name"
  printf '  old pid: %s\n' "$pid"
  printf '  cwd: %s\n' "$cwd"

  stop_process_group "$name" "$pid"

  if port_is_listening "$port"; then
    port_registry_remove_name "$name"
    port_die "port is still listening after stopping $name: $port"
  fi

  port_registry_remove_name "$name"
  start_restarted_service "$name" "$port" "$cwd" "$command_text"
}

if [[ "$#" -eq 0 ]]; then
  read_interactive_targets
  set -- "${PORT_RESTART_INTERACTIVE_TARGETS[@]}"
fi

for target in "$@"; do
  if [[ "$target" == "--all" ]]; then
    usage >&2
    port_die "port-restart does not support --all"
  fi
done

if [[ "$#" -eq 0 ]]; then
  usage >&2
  port_die "expected at least one service name/port"
fi

port_registry_init
port_registry_lock
port_registry_cleanup_stale

declare -A seen_names=()
lines=()
cwds=()

for target in "$@"; do
  line="$(registry_line_for_target "$target")"
  port_parse_registry_line "$line"

  if [[ -n "${seen_names[$PORT_ENTRY_NAME]+x}" ]]; then
    continue
  fi

  if ! port_service_alive "$PORT_ENTRY_PID"; then
    port_die "named port service is no longer running: $PORT_ENTRY_NAME"
  fi

  cwd="$(readlink -- "/proc/$PORT_ENTRY_PID/cwd" 2>/dev/null || true)"
  [[ -n "$cwd" && -d "$cwd" ]] ||
    port_die "failed to read working directory for named port service: $PORT_ENTRY_NAME"
  [[ -n "$PORT_ENTRY_COMMAND" ]] ||
    port_die "recorded command is empty for named port service: $PORT_ENTRY_NAME"

  seen_names["$PORT_ENTRY_NAME"]=1
  lines+=("$line")
  cwds+=("$cwd")
done

if (( ${#lines[@]} > 1 )); then
  printf 'Restarting %d named port service(s).\n' "${#lines[@]}"
fi

for index in "${!lines[@]}"; do
  restart_registry_line "${lines[$index]}" "${cwds[$index]}"
done
