#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'USAGE'
Usage:
  cli-tools ssh-tunnel
  cli-tools ssh-tunnel --all
  cli-tools ssh-tunnel --help

Create SSH local port forwards using CLI_TOOLS_SSH_REMOTE from .env.
After you enter ports, the command prints local URLs you can open.

With --all, fetch active named remote ports, forward all of them, then keep an
interactive prompt open:
  s + Enter  refresh remote ports
  q + Enter  stop tunnel and quit

Example input:
  8087 8088
USAGE
}

die() {
  printf 'error: %s\n' "$*" >&2
  exit 1
}

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || die "required command not found: $1"
}

resolve_self() {
  local source="$1"
  local dir link

  while [[ -L "$source" ]]; do
    dir="$(CDPATH= cd -- "$(dirname -- "$source")" && pwd)"
    link="$(readlink -- "$source")" || return 1

    if [[ "$link" == /* ]]; then
      source="$link"
    else
      source="$dir/$link"
    fi
  done

  dir="$(CDPATH= cd -- "$(dirname -- "$source")" && pwd)"
  printf '%s/%s\n' "$dir" "$(basename -- "$source")"
}

strip_matching_quotes() {
  local value="$1"
  local length="${#value}"

  if [[ "$length" -ge 2 ]]; then
    if [[ "${value:0:1}" == '"' && "${value:length-1:1}" == '"' ]]; then
      value="${value:1:length-2}"
    elif [[ "${value:0:1}" == "'" && "${value:length-1:1}" == "'" ]]; then
      value="${value:1:length-2}"
    fi
  fi

  printf '%s\n' "$value"
}

load_env_value() {
  local env_file="$1"
  local key="$2"
  local line value=""

  [[ -f "$env_file" ]] || die "missing .env file: $env_file"

  while IFS= read -r line || [[ -n "$line" ]]; do
    case "$line" in
      ""|\#*) continue ;;
      "$key"=*)
        value="${line#"$key"=}"
        ;;
    esac
  done <"$env_file"

  strip_matching_quotes "$value"
}

load_remote_config() {
  local env_file="$repo_root/.env"

  remote="$(load_env_value "$env_file" "CLI_TOOLS_SSH_REMOTE")"
  [[ -n "$remote" ]] || die "missing CLI_TOOLS_SSH_REMOTE in $env_file"
  case "$remote" in
    *[[:space:]]*) die "CLI_TOOLS_SSH_REMOTE must not contain whitespace" ;;
  esac

  remote_cli="$(load_env_value "$env_file" "CLI_TOOLS_REMOTE_CLI")"
  case "$remote_cli" in
    *[[:space:]]*) die "CLI_TOOLS_REMOTE_CLI must not contain whitespace" ;;
  esac
}

is_port_number() {
  local port="$1"

  [[ "$port" =~ ^[0-9]+$ ]] || return 1
  (( port >= 1 && port <= 65535 ))
}

add_port() {
  local port="$1"
  local name="${2:-}"

  is_port_number "$port" || die "invalid port: $port"
  [[ -z "${seen_ports[$port]:-}" ]] || die "duplicate port: $port"
  seen_ports[$port]=1
  ports+=("$port")
  port_names+=("$name")
}

remote_port_list_command() {
  cat <<'REMOTE_COMMAND'
if command -v cli-tools >/dev/null 2>&1; then
  exec cli-tools port-list
elif [ -x "$HOME/cli-tools/bin/cli-tools" ]; then
  exec "$HOME/cli-tools/bin/cli-tools" port-list
elif [ -x "$HOME/.local/bin/cli-tools" ]; then
  exec "$HOME/.local/bin/cli-tools" port-list
elif [ -x "$HOME/miniconda3/bin/cli-tools" ]; then
  exec "$HOME/miniconda3/bin/cli-tools" port-list
fi

printf "%s\n" "error: remote cli-tools not found; set CLI_TOOLS_REMOTE_CLI in local .env to the remote cli-tools path" >&2
exit 127
REMOTE_COMMAND
}

fetch_remote_port_list() {
  local remote_command output

  if [[ -n "$remote_cli" ]]; then
    if ! output="$(ssh -S "$control_socket" "$remote" "$remote_cli" port-list 2>&1)"; then
      printf '%s\n' "$output" >&2
      die "failed to get remote port list"
    fi
  else
    remote_command="$(remote_port_list_command)"
    if ! output="$(ssh -S "$control_socket" "$remote" "$remote_command" 2>&1)"; then
      printf '%s\n' "$output" >&2
      die "failed to get remote port list"
    fi
  fi

  printf '%s\n' "$output"
}

load_all_remote_ports() {
  local output line name port status rest

  ports=()
  port_names=()
  seen_ports=()

  output="$(fetch_remote_port_list)"

  while IFS= read -r line || [[ -n "$line" ]]; do
    [[ -n "$line" ]] || continue
    [[ "$line" == Remote\ named\ port\ services\ on\ * ]] && continue
    [[ "$line" == "No named port services." ]] && continue
    [[ "$line" == NAME[[:space:]]* ]] && continue
    [[ "$line" == "  command:"* ]] && continue

    read -r name port status rest <<<"$line"
    [[ -n "${name:-}" && -n "${port:-}" ]] || continue
    is_port_number "$port" || continue

    add_port "$port" "$name"
  done <<<"$output"
}

safe_remote_name() {
  printf '%s' "$remote" | tr -c 'A-Za-z0-9._@-' '_'
}

start_master() {
  local socket_dir safe_remote

  socket_dir="$repo_root/.cache/ssh-tunnel"
  mkdir -p "$socket_dir"
  safe_remote="$(safe_remote_name)"
  control_socket="$socket_dir/${safe_remote}-$$.sock"

  printf 'Starting SSH master to %s...\n' "$remote"
  if ! ssh -M -S "$control_socket" -N -f "$remote"; then
    die "failed to start SSH master tunnel"
  fi
  master_started=1
}

stop_master() {
  if [[ "${master_started:-0}" -eq 1 ]]; then
    ssh -S "$control_socket" -O exit "$remote" >/dev/null 2>&1 || true
    master_started=0
  fi

  if [[ -n "${control_socket:-}" ]]; then
    rm -f -- "$control_socket"
  fi
}

handle_signal() {
  printf '\nStopping SSH tunnel...\n' >&2
  stop_master
  exit 130
}

forward_port() {
  local port="$1"

  if ! ssh -S "$control_socket" -O forward -o ExitOnForwardFailure=yes \
    -L "$port:127.0.0.1:$port" "$remote"; then
    die "failed to forward port: $port"
  fi
}

cancel_forward_port() {
  local port="$1"

  if ! ssh -S "$control_socket" -O cancel \
    -L "$port:127.0.0.1:$port" "$remote"; then
    die "failed to cancel forwarded port: $port"
  fi
}

print_forwarded_urls() {
  local port name sort_key

  printf 'Open:\n'
  while IFS=$'\t' read -r sort_key port; do
    [[ -n "$port" ]] || continue
    name="${forwarded_names[$port]:-}"
    if [[ -n "$name" ]]; then
      printf '  %s -> http://127.0.0.1:%s/\n' "$name" "$port"
    else
      printf '  http://127.0.0.1:%s/\n' "$port"
    fi
  done < <(
    for port in "${forwarded_order[@]}"; do
      name="${forwarded_names[$port]:-}"
      if [[ -n "$name" ]]; then
        printf '%s\t%s\n' "$name" "$port"
      else
        printf '%s\t%s\n' "$port" "$port"
      fi
    done | sort -f -t $'\t' -k1,1 -k2,2n
  )
}

refresh_all_ports() {
  local heading="$1"
  local require_any="${2:-0}"
  local index port name
  local added=0 removed=0 updated=0
  local -A remote_ports=()
  local -a next_forwarded_order=()

  load_all_remote_ports

  if [[ "${#ports[@]}" -eq 0 && "$require_any" -eq 1 ]]; then
    die "no active remote named port services found"
  fi

  for index in "${!ports[@]}"; do
    port="${ports[$index]}"
    name="${port_names[$index]}"
    remote_ports[$port]=1
  done

  for port in "${forwarded_order[@]}"; do
    [[ -n "${forwarded_ports[$port]:-}" ]] || continue
    if [[ -z "${remote_ports[$port]:-}" ]]; then
      cancel_forward_port "$port"
      unset "forwarded_ports[$port]"
      unset "forwarded_names[$port]"
      removed=$((removed + 1))
    fi
  done

  for port in "${forwarded_order[@]}"; do
    if [[ -n "${forwarded_ports[$port]:-}" ]]; then
      next_forwarded_order+=("$port")
    fi
  done
  forwarded_order=("${next_forwarded_order[@]}")

  for index in "${!ports[@]}"; do
    port="${ports[$index]}"
    name="${port_names[$index]}"

    if [[ -n "${forwarded_ports[$port]:-}" ]]; then
      if [[ "${forwarded_names[$port]:-}" != "$name" ]]; then
        forwarded_names[$port]="$name"
        updated=$((updated + 1))
      fi
      continue
    fi

    forward_port "$port"
    forwarded_ports[$port]=1
    forwarded_names[$port]="$name"
    forwarded_order+=("$port")
    added=$((added + 1))
  done

  if [[ "$heading" != "Open" ]]; then
    if [[ "$added" -eq 0 && "$removed" -eq 0 && "$updated" -eq 0 ]]; then
      printf 'Remote named ports are already up to date.\n'
    else
      printf 'Refreshed remote named ports: added %s, removed %s, updated %s.\n' \
        "$added" "$removed" "$updated"
    fi
  fi

  print_forwarded_urls
}

print_loop_help() {
  cat <<'HELP'

Commands:
  s + Enter  refresh remote ports
  q + Enter  stop tunnel and quit
HELP
}

run_all_mode() {
  local action

  master_started=0
  control_socket=""
  declare -gA forwarded_ports=()
  declare -gA forwarded_names=()
  declare -ga forwarded_order=()

  trap stop_master EXIT
  trap handle_signal INT TERM

  start_master
  refresh_all_ports "Open" 1
  print_loop_help

  while true; do
    printf '\nssh-tunnel> '
    if ! IFS= read -r action; then
      printf '\n'
      break
    fi

    case "$action" in
      "" )
        ;;
      s|sync|refresh|r )
        refresh_all_ports "Refresh" 0
        ;;
      q|quit|exit )
        break
        ;;
      h|help|\? )
        print_loop_help
        ;;
      * )
        printf 'Unknown command: %s\n' "$action" >&2
        print_loop_help
        ;;
    esac
  done

  printf 'Stopping SSH tunnel...\n'
  stop_master
  trap - EXIT INT TERM
}

run_manual_mode() {
  local ports_line port index name
  local ssh_args=(-N)

  ports=()
  port_names=()
  declare -gA seen_ports=()

  printf 'Ports to forward, separated by spaces: '
  if ! IFS= read -r ports_line; then
    die "failed to read ports"
  fi

  for port in $ports_line; do
    add_port "$port" ""
  done

  [[ "${#ports[@]}" -gt 0 ]] || die "at least one port is required"

  for port in "${ports[@]}"; do
    ssh_args+=(-L "$port:127.0.0.1:$port")
  done
  ssh_args+=("$remote")

  printf 'Open:\n'
  for index in "${!ports[@]}"; do
    port="${ports[$index]}"
    name="${port_names[$index]}"
    if [[ -n "$name" ]]; then
      printf '  %s -> http://127.0.0.1:%s/\n' "$name" "$port"
    else
      printf '  http://127.0.0.1:%s/\n' "$port"
    fi
  done

  printf 'Starting SSH tunnel to %s. Press Ctrl-C to stop.\n' "$remote"
  exec ssh "${ssh_args[@]}"
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

forward_all=0
if [[ "${1:-}" == "--all" ]]; then
  forward_all=1
  shift
fi

if [[ "$#" -ne 0 ]]; then
  usage >&2
  die "expected no arguments or --all"
fi

require_cmd ssh

script_path="$(resolve_self "${BASH_SOURCE[0]}")" || die "failed to resolve script path"
repo_root="$(CDPATH= cd -- "$(dirname -- "$script_path")/.." && pwd)"
remote=""
remote_cli=""
load_remote_config

ports=()
port_names=()
declare -A seen_ports=()

if [[ "$forward_all" -eq 1 ]]; then
  run_all_mode
else
  run_manual_mode
fi
