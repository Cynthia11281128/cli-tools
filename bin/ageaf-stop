#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'USAGE'
Usage:
  cli-tools ageaf-stop [--name NAME]
  ageaf-stop [--name NAME]

Stop the Ageaf background service started by `cli-tools ageaf-start`.

Options:
  --name NAME  Named port service name. Defaults to ageaf.
  -h, --help   Show this help.
USAGE
}

die() {
  printf 'error: %s\n' "$*" >&2
  exit 1
}

resolve_self() {
  local source="$1"
  local dir link

  while [[ -L "$source" ]]; do
    dir="$(CDPATH= cd -- "$(dirname -- "$source")" && pwd)" || return 1
    link="$(readlink -- "$source")" || return 1

    if [[ "$link" == /* ]]; then
      source="$link"
    else
      source="$dir/$link"
    fi
  done

  dir="$(CDPATH= cd -- "$(dirname -- "$source")" && pwd)" || return 1
  printf '%s/%s\n' "$dir" "$(basename -- "$source")"
}

script_path="$(resolve_self "${BASH_SOURCE[0]}")" || die "failed to resolve script path"
bin_dir="$(dirname -- "$script_path")"
name="ageaf"

while [[ "$#" -gt 0 ]]; do
  case "$1" in
    -h|--help)
      usage
      exit 0
      ;;
    --name)
      [[ "$#" -ge 2 ]] || die "missing value for --name"
      name="$2"
      shift 2
      ;;
    --name=*)
      name="${1#--name=}"
      shift
      ;;
    *)
      die "unknown argument: $1"
      ;;
  esac
done

exec "$bin_dir/port-stop" "$name"
