#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'USAGE'
Usage:
  cli-tools port-clear-cache
  port-clear-cache

Clear the named port service cache, including registry and logs.

This command refuses to run while any named port service is still active. Stop
active services with `cli-tools port-stop <name>` first.
USAGE
}

resolve_self() {
  local source="$1"
  local dir link

  while [[ -L "$source" ]]; do
    dir="$(CDPATH= cd -- "$(dirname -- "$source")" && pwd)" || return 1
    link="$(readlink -- "$source")" || return 1

    if [[ "$link" == /* ]]; then
      source="$link"
    else
      source="$dir/$link"
    fi
  done

  dir="$(CDPATH= cd -- "$(dirname -- "$source")" && pwd)" || return 1
  printf '%s/%s\n' "$dir" "$(basename -- "$source")"
}

script_path="$(resolve_self "${BASH_SOURCE[0]}")" || {
  printf 'error: failed to resolve script path\n' >&2
  exit 1
}
bin_dir="$(dirname -- "$script_path")"
repo_dir="$(CDPATH= cd -- "$bin_dir/.." && pwd)" || {
  printf 'error: failed to resolve cli-tools root\n' >&2
  exit 1
}

# shellcheck source=../lib/port-registry.bash
source "$repo_dir/lib/port-registry.bash"

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

if [[ "$#" -ne 0 ]]; then
  usage >&2
  port_die "this command does not accept arguments"
fi

port_registry_lock
port_registry_cleanup_stale

if [[ "$(port_registry_count_entries)" -ne 0 ]]; then
  printf 'Active named port services are still running:\n' >&2
  port_registry_print_entries >&2
  port_die "stop active services before clearing the port cache"
fi

if [[ -d "$PORT_CACHE_DIR" ]]; then
  rm -rf -- "$PORT_CACHE_DIR"
  printf 'Cleared port cache: %s\n' "$PORT_CACHE_DIR"
else
  printf 'Port cache is already clear: %s\n' "$PORT_CACHE_DIR"
fi
