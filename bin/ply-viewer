#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'USAGE'
Usage:
  cli-tools ply-viewer [PLY_PATH] [--port PORT] [--name NAME] [--host HOST]
  cli-tools ply-viewer --sequence SNAPSHOT_DIR [--port PORT] [--name NAME] [--host HOST]
  ply-viewer [PLY_PATH] [--port PORT] [--name NAME] [--host HOST]
  ply-viewer --sequence SNAPSHOT_DIR [--port PORT] [--name NAME] [--host HOST]

Start a lightweight web viewer for an ordinary mesh or point-cloud PLY file,
or for a directory of PlanarSplatting optimization snapshot PLY files.
If PLY_PATH is omitted and --sequence is not set, the command prompts for the
path and service name interactively.

Options:
  --sequence DIR   Load a snapshot directory as a timeline.
  --port PORT      Port to use. Defaults to an automatically selected free port.
  --name NAME      Named port service name. Defaults to ply-view-<port>.
  --host HOST      Bind host for the web server. Defaults to 127.0.0.1.
  -h, --help       Show this help.

Examples:
  cli-tools ply-viewer
  cli-tools ply-viewer ~/outputs/scene0000_00_planar_mesh.ply
  cli-tools ply-viewer --sequence ~/outputs/exp/optimization_snapshots
  cli-tools ply-viewer /data/model.ply --port 8765 --name my-ply
USAGE
}

die() {
  printf 'error: %s\n' "$*" >&2
  exit 1
}

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || die "missing required command: $1"
}

resolve_self() {
  local source="$1"
  local dir link

  while [[ -L "$source" ]]; do
    dir="$(CDPATH= cd -- "$(dirname -- "$source")" && pwd)" || return 1
    link="$(readlink -- "$source")" || return 1

    if [[ "$link" == /* ]]; then
      source="$link"
    else
      source="$dir/$link"
    fi
  done

  dir="$(CDPATH= cd -- "$(dirname -- "$source")" && pwd)" || return 1
  printf '%s/%s\n' "$dir" "$(basename -- "$source")"
}

expand_path() {
  local path="$1"

  case "$path" in
    "~")
      printf '%s\n' "$HOME"
      ;;
    "~/"*)
      printf '%s/%s\n' "$HOME" "${path#"~/"}"
      ;;
    *)
      printf '%s\n' "$path"
      ;;
  esac
}

validate_port() {
  local port="$1"

  [[ "$port" =~ ^[0-9]+$ ]] ||
    die "invalid port: $port; expected an integer from 1 to 65535"
  (( port >= 1 && port <= 65535 )) ||
    die "invalid port: $port; expected an integer from 1 to 65535"
}

find_free_port() {
  local host="$1"

  python3 - "$host" <<'PY'
import socket
import sys

host = sys.argv[1]
with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as sock:
    sock.bind((host, 0))
    print(sock.getsockname()[1])
PY
}

script_path="$(resolve_self "${BASH_SOURCE[0]}")" || die "failed to resolve script path"
bin_dir="$(dirname -- "$script_path")"
repo_dir="$(CDPATH= cd -- "$bin_dir/.." && pwd)" || die "failed to resolve cli-tools root"
server_path="$repo_dir/lib/ply-viewer/server.py"

host="127.0.0.1"
port=""
name=""
ply_input=""
sequence_input=""
prompted_for_ply_path="no"

while [[ "$#" -gt 0 ]]; do
  case "$1" in
    -h|--help)
      usage
      exit 0
      ;;
    --port)
      [[ "$#" -ge 2 ]] || die "missing value for --port"
      port="$2"
      shift 2
      ;;
    --port=*)
      port="${1#--port=}"
      shift
      ;;
    --name)
      [[ "$#" -ge 2 ]] || die "missing value for --name"
      name="$2"
      shift 2
      ;;
    --name=*)
      name="${1#--name=}"
      shift
      ;;
    --sequence)
      [[ "$#" -ge 2 ]] || die "missing value for --sequence"
      sequence_input="$2"
      shift 2
      ;;
    --sequence=*)
      sequence_input="${1#--sequence=}"
      shift
      ;;
    --host)
      [[ "$#" -ge 2 ]] || die "missing value for --host"
      host="$2"
      shift 2
      ;;
    --host=*)
      host="${1#--host=}"
      shift
      ;;
    --)
      shift
      [[ "$#" -le 1 ]] || die "expected at most one PLY path"
      if [[ "$#" -eq 1 ]]; then
        ply_input="$1"
      fi
      shift "$#"
      ;;
    -*)
      die "unknown option: $1"
      ;;
    *)
      [[ -z "$ply_input" ]] || die "expected at most one PLY path"
      ply_input="$1"
      shift
      ;;
  esac
done

require_cmd python3
require_cmd realpath

[[ -f "$server_path" ]] || die "missing PLY viewer server: $server_path"
[[ -z "$ply_input" || -z "$sequence_input" ]] || die "PLY_PATH and --sequence cannot be used together"

if [[ -z "$ply_input" && -z "$sequence_input" ]]; then
  printf 'PLY path: ' >&2
  IFS= read -r ply_input || die "failed to read PLY path"
  prompted_for_ply_path="yes"
fi

[[ -n "$ply_input" || -n "$sequence_input" ]] || die "PLY path or --sequence is required"

ply_path=""
sequence_path=""

if [[ -n "$ply_input" ]]; then
  expanded_ply="$(expand_path "$ply_input")"
  [[ -f "$expanded_ply" ]] || die "PLY file does not exist: $expanded_ply"

  ply_path="$(realpath -- "$expanded_ply")" || die "failed to resolve PLY path: $expanded_ply"
  lower_ply_path="${ply_path,,}"
  [[ "$lower_ply_path" == *.ply ]] || die "expected a .ply file: $ply_path"
else
  expanded_sequence="$(expand_path "$sequence_input")"
  [[ -d "$expanded_sequence" ]] || die "sequence directory does not exist: $expanded_sequence"

  sequence_path="$(realpath -- "$expanded_sequence")" || die "failed to resolve sequence directory: $expanded_sequence"
fi

if [[ -n "$port" ]]; then
  validate_port "$port"
else
  port="$(find_free_port "$host")" || die "failed to find a free port for host: $host"
fi

if [[ -z "$name" && "$prompted_for_ply_path" == "yes" && -t 0 ]]; then
  default_name="ply-view-$port"
  printf 'Service name [%s]: ' "$default_name" >&2
  IFS= read -r name_input || die "failed to read service name"
  if [[ -n "$name_input" ]]; then
    name="$name_input"
  fi
fi

if [[ -z "$name" ]]; then
  name="ply-view-$port"
fi

server_args=(python3 "$server_path" --port "$port" --host "$host" --name "$name")
if [[ -n "$sequence_path" ]]; then
  server_args+=(--sequence "$sequence_path")
else
  server_args+=(--ply "$ply_path")
fi

"$bin_dir/port-start" "$name" "$port" -- "${server_args[@]}"

url_host="$host"
if [[ "$url_host" == "0.0.0.0" || "$url_host" == "::" ]]; then
  url_host="127.0.0.1"
fi

printf 'Viewer URL: http://%s:%s/\n' "$url_host" "$port"
if [[ -n "$sequence_path" ]]; then
  printf 'PLY sequence: %s\n' "$sequence_path"
else
  printf 'PLY file: %s\n' "$ply_path"
fi
printf 'Remote access: run cli-tools ssh-tunnel --all from your local machine.\n'
