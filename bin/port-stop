#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'USAGE'
Usage:
  cli-tools port-stop
  cli-tools port-stop <name-or-port> [...]
  cli-tools port-stop --all
  port-stop
  port-stop <name-or-port> [...]
  port-stop --all

Stop one or more named port services managed by cli-tools.

Run without arguments to choose one or more services interactively.

The command sends TERM to the service process group, waits briefly, then sends
KILL if the service is still running.

Targets may be service names or managed port numbers. Numeric targets are
resolved as ports first, then service names.

With --all, stop every active named port service managed by cli-tools.
USAGE
}

resolve_self() {
  local source="$1"
  local dir link

  while [[ -L "$source" ]]; do
    dir="$(CDPATH= cd -- "$(dirname -- "$source")" && pwd)" || return 1
    link="$(readlink -- "$source")" || return 1

    if [[ "$link" == /* ]]; then
      source="$link"
    else
      source="$dir/$link"
    fi
  done

  dir="$(CDPATH= cd -- "$(dirname -- "$source")" && pwd)" || return 1
  printf '%s/%s\n' "$dir" "$(basename -- "$source")"
}

script_path="$(resolve_self "${BASH_SOURCE[0]}")" || {
  printf 'error: failed to resolve script path\n' >&2
  exit 1
}
bin_dir="$(dirname -- "$script_path")"
repo_dir="$(CDPATH= cd -- "$bin_dir/.." && pwd)" || {
  printf 'error: failed to resolve cli-tools root\n' >&2
  exit 1
}

# shellcheck source=../lib/port-registry.bash
source "$repo_dir/lib/port-registry.bash"

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

stop_registry_line() {
  local line="$1"

  port_parse_registry_line "$line"

  if ! port_service_alive "$PORT_ENTRY_PID"; then
    port_registry_remove_name "$PORT_ENTRY_NAME"
    printf 'Removed stale named port service: %s\n' "$PORT_ENTRY_NAME"
    return 0
  fi

  printf 'Stopping named port service: %s\n' "$PORT_ENTRY_NAME"
  printf '  port: %s\n' "$PORT_ENTRY_PORT"
  printf '  pid: %s\n' "$PORT_ENTRY_PID"

  kill -TERM -- "-$PORT_ENTRY_PID" 2>/dev/null || true

  for ((attempt = 1; attempt <= 50; attempt++)); do
    if ! port_service_alive "$PORT_ENTRY_PID"; then
      break
    fi
    sleep 0.1
  done

  if port_service_alive "$PORT_ENTRY_PID"; then
    port_warn "service did not stop after TERM; sending KILL"
    kill -KILL -- "-$PORT_ENTRY_PID" 2>/dev/null || true
    sleep 0.2
  fi

  if port_service_alive "$PORT_ENTRY_PID"; then
    port_warn "service still appears to be running; removing registry entry anyway"
  fi

  port_registry_remove_name "$PORT_ENTRY_NAME"
  printf 'Stopped named port service: %s\n' "$PORT_ENTRY_NAME"
}

port_number_for_target() {
  local target="$1"
  local port_number

  [[ "$target" =~ ^[0-9]+$ ]] || return 1
  port_number=$((10#$target))
  (( port_number >= 1 && port_number <= 65535 )) || return 1
  printf '%s\n' "$port_number"
}

registry_line_for_target() {
  local target="$1"
  local target_port=""
  local line=""

  if target_port="$(port_number_for_target "$target")"; then
    line="$(port_registry_line_by_port "$target_port" || true)"
    if [[ -n "$line" ]]; then
      printf '%s\n' "$line"
      return 0
    fi
  fi

  port_validate_name "$target"

  line="$(port_registry_line_by_name "$target" || true)"
  if [[ -n "$line" ]]; then
    printf '%s\n' "$line"
    return 0
  fi

  if [[ "$target" =~ ^[0-9]+$ ]]; then
    if [[ -n "$target_port" ]]; then
      port_die "unknown named port service or managed port: $target"
    fi
    port_die "unknown named port service, and not a valid port: $target"
  fi

  port_die "unknown named port service: $target"
}

read_interactive_targets() {
  local -a lines=()
  local -a tokens=()
  local line name port pid start_time log_path command_text
  local index selection selected_index token
  local name_width=4 port_width=4

  if [[ ! -t 0 || ! -t 1 ]]; then
    usage >&2
    port_die "interactive mode requires a terminal; pass <name-or-port> or --all for non-interactive use"
  fi

  port_registry_lock
  port_registry_cleanup_stale

  if [[ "$(port_registry_count_entries)" -eq 0 ]]; then
    port_registry_unlock
    printf 'No named port services.\n'
    exit 0
  fi

  mapfile -t lines < <(sort -f -t $'\t' -k1,1 -k2,2n -- "$PORT_REGISTRY")
  port_registry_unlock

  for line in "${lines[@]}"; do
    [[ -n "$line" ]] || continue
    IFS=$'\t' read -r name port pid start_time log_path command_text <<<"$line"
    if (( ${#name} > name_width )); then
      name_width="${#name}"
    fi
    if (( ${#port} > port_width )); then
      port_width="${#port}"
    fi
  done

  printf 'Available named port services:\n'
  printf '  %-4s %-*s %-*s %s\n' "#" "$name_width" "NAME" "$port_width" "PORT" "PID"

  index=1
  for line in "${lines[@]}"; do
    [[ -n "$line" ]] || continue
    IFS=$'\t' read -r name port pid start_time log_path command_text <<<"$line"
    printf '  %-4s %-*s %-*s %s\n' "$index" "$name_width" "$name" "$port_width" "$port" "$pid"
    index=$((index + 1))
  done

  printf 'Select service(s) to stop (numbers, names, or ports; separate with spaces or commas): '
  IFS= read -r selection || port_die "selection is required"
  [[ -n "$selection" ]] || port_die "selection is required"

  selection="${selection//,/ }"
  read -r -a tokens <<<"$selection"
  [[ "${#tokens[@]}" -gt 0 ]] || port_die "selection is required"

  PORT_STOP_INTERACTIVE_TARGETS=()
  for token in "${tokens[@]}"; do
    if [[ "$token" =~ ^[0-9]+$ ]]; then
      selected_index=$((10#$token))
      if (( selected_index >= 1 && selected_index <= ${#lines[@]} )); then
        line="${lines[$((selected_index - 1))]}"
        IFS=$'\t' read -r name port pid start_time log_path command_text <<<"$line"
        token="$name"
      fi
    fi

    PORT_STOP_INTERACTIVE_TARGETS+=("$token")
  done
}

if [[ "$#" -eq 0 ]]; then
  read_interactive_targets
  set -- "${PORT_STOP_INTERACTIVE_TARGETS[@]}"
fi

if [[ "$#" -eq 1 && "${1:-}" == "--all" ]]; then
  port_registry_lock
  port_registry_cleanup_stale

  if [[ "$(port_registry_count_entries)" -eq 0 ]]; then
    printf 'No named port services.\n'
    exit 0
  fi

  mapfile -t lines <"$PORT_REGISTRY"
  printf 'Stopping %d named port service(s).\n' "${#lines[@]}"

  for line in "${lines[@]}"; do
    [[ -n "$line" ]] || continue
    stop_registry_line "$line"
  done

  printf 'Stopped all named port services.\n'
  exit 0
fi

for target in "$@"; do
  if [[ "$target" == "--all" ]]; then
    usage >&2
    port_die "--all cannot be combined with service names or ports"
  fi
done

port_registry_lock
port_registry_cleanup_stale

declare -A seen_names=()
lines=()

for target in "$@"; do
  line="$(registry_line_for_target "$target")"
  port_parse_registry_line "$line"

  if [[ -n "${seen_names[$PORT_ENTRY_NAME]+x}" ]]; then
    continue
  fi

  seen_names["$PORT_ENTRY_NAME"]=1
  lines+=("$line")
done

if (( ${#lines[@]} > 1 )); then
  printf 'Stopping %d named port service(s).\n' "${#lines[@]}"
fi

for line in "${lines[@]}"; do
  stop_registry_line "$line"
done
